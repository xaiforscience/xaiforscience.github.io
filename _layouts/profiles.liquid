---
layout: page
---
<div class="post">
  <article>
    {% if page.profiles %}
      <div class="people-grid">
        {% for profile in page.profiles %}
          <div class="person-card">
            {% if profile.image %}
              {% assign profile_image_path = profile.image | prepend: 'assets/img/' %}
              {% include figure.liquid loading="eager" path=profile_image_path class="img-fluid rounded" alt=profile.name %}
            {% endif %}
            {% if profile.name %}
              <p class="person-name">{{ profile.name }}</p>
            {% endif %}
            {% if profile.title %}
              <p class="person-title">{{ profile.title }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </article>
</div>

<style>
.people-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 2rem;
  margin-top: 2rem;
}
.person-card {
  text-align: center;
}
.person-card img {
  width: 100%;
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 8px;
}
.person-name {
  margin: 0.5rem 0 0.1rem;
  font-weight: 600;
  font-size: 0.95rem;
}
.person-title {
  margin: 0;
  font-size: 0.8rem;
  color: var(--global-text-color-light, #888);
}
</style>
